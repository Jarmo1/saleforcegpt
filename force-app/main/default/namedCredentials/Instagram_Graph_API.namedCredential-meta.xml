<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <label>Instagram Graph API</label>
    <principalType>NamedUser</principalType>
    <protocol>NoAuthentication</protocol>
    <url>https://graph.instagram.com</url>
    <!--
        SETUP INSTRUCTIONS (Instagram API with Instagram Login — July 2024+):
        1. Complete the OAuth flow via InstagramOAuthService to obtain a long-lived token
        2. Go to Setup → Named Credentials → Instagram Graph API
        3. Set Protocol to "Custom" (No Authentication)
        4. Add a custom header: Authorization → Bearer {YOUR_LONG_LIVED_INSTAGRAM_USER_TOKEN}
        5. The token is valid for 60 days — InstagramTokenRefreshScheduler renews it automatically

        Required Meta App permissions:
          instagram_business_basic
          instagram_manage_messages

        NOTE: Do NOT use graph.facebook.com — the Instagram Login API uses graph.instagram.com
    -->
</NamedCredential>
