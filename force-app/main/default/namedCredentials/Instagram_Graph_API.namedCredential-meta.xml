<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <label>Instagram Graph API</label>
    <principalType>NamedUser</principalType>
    <protocol>NoAuthentication</protocol>
    <url>https://graph.facebook.com</url>
    <!--
        SETUP INSTRUCTIONS:
        Instagram DMs use the same Graph API endpoint as Facebook Messenger.
        1. Go to Setup → Named Credentials → Instagram Graph API
        2. Add your Instagram Professional Account's Page Access Token
        3. Ensure instagram_manage_messages permission is granted
    -->
</NamedCredential>
