<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>true</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <label>Instagram OAuth API</label>
    <principalType>Anonymous</principalType>
    <protocol>NoAuthentication</protocol>
    <url>https://api.instagram.com</url>
    <!--
        Used by InstagramOAuthService for the token exchange steps:
          POST /oauth/access_token   (code → short-lived token)

        No authentication header needed — credentials are sent in the request body.

        Required Remote Site Setting:
          Name: Instagram_OAuth_API
          URL:  https://api.instagram.com
    -->
</NamedCredential>
