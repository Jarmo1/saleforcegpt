<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <label>Facebook Graph API</label>
    <oauthScope>pages_messaging</oauthScope>
    <principalType>NamedUser</principalType>
    <protocol>NoAuthentication</protocol>
    <url>https://graph.facebook.com</url>
    <!--
        SETUP INSTRUCTIONS:
        1. Go to Setup → Named Credentials → Facebook Graph API
        2. Change Protocol to "Custom" or use "OAuth 2.0"
        3. Add your Facebook Page Access Token as a header:
           Header: Authorization, Value: Bearer {YOUR_PAGE_ACCESS_TOKEN}
        4. Alternatively, append ?access_token={token} in each callout
           (the Apex service classes support both methods)
    -->
</NamedCredential>
